# Supabase — get these from your project at https://app.supabase.com
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: the public URL of your deployment, used to build magic-link
# redirect URLs. In local dev this defaults to http://localhost:3000.
# On Vercel this is provided automatically as NEXT_PUBLIC_SITE_URL if you set it.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
